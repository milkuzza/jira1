# ─── SMTP / Email ─────────────────────────────────────────────────────────────
# Option A: Gmail (free, recommended for small deployments)
#   1. Enable 2FA on your Google account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an app password for "Mail"
#   4. Use those credentials below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password

# Option B: Mailtrap (free, for development — emails are trapped, never delivered)
#   Register at https://mailtrap.io, create an inbox, copy SMTP credentials
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=<mailtrap-user>
# SMTP_PASS=<mailtrap-pass>

# Option C: Yandex.Mail (free for personal use)
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@yandex.ru
# SMTP_PASS=your-yandex-app-password

# Option D: Leave all SMTP_ vars unset → Ethereal fake SMTP is used automatically
#   Emails are not delivered; preview URLs are printed in the API logs.

# Sender identity
SMTP_FROM_NAME=ProjectHub
SMTP_FROM_ADDR=noreply@projecthub.app

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=projecthub

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Frontend URL (used in email links) ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173
